{
  "manifest_version": 3,
  "name": "LiveChat Session ID Copier",
  "version": "1.4.0",
  "description": "LiveChat arşiv sayfalarında network isteklerini dinler, Session ID'yi yakalar ve popup ekranından veya sayfa üzerinden panoya kopyalamayı sağlar.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "webRequest",
    "storage",
    "clipboardWrite",
    "activeTab",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "*://my.livechatinc.com/*"
      ],
      "js": [
        "interceptor.js"
      ],
      "world": "MAIN",
      "run_at": "document_start"
    },
    {
      "matches": [
        "*://my.livechatinc.com/*"
      ],
      "js": [
        "content_script.js"
      ],
      "run_at": "document_idle"
    }
  ]
}